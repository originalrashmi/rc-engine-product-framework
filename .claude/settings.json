{
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/**)",
      "Read(**/.config/gcloud/**)",
      "Read(**/.docker/config.json)",
      "Read(**/.kube/config)",
      "Read(**/.npmrc)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/credentials.json)",
      "Read(**/secrets/**)",
      "Edit(**/.env)",
      "Edit(**/.env.local)",
      "Edit(**/.env.production)",
      "Edit(**/.ssh/**)",
      "Edit(**/credentials.json)",
      "Edit(**/secrets/**)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Write(**/.env)",
      "Write(**/.env.local)",
      "Write(**/.env.production)",
      "Write(**/.ssh/**)",
      "Write(**/credentials.json)",
      "Write(**/secrets/**)",
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(chmod 777 *)",
      "Bash(curl * | bash)",
      "Bash(wget * | bash)"
    ],
    "allow": [
      "Read(src/**)",
      "Read(knowledge/**)",
      "Read(docs/**)",
      "Read(CLAUDE.md)",
      "Read(AGENTS.md)",
      "Read(package.json)",
      "Read(tsconfig.json)",
      "Read(.mcp.json)",
      "Read(.claude/agents/**)",
      "Read(.claude/rules/**)",
      "Bash(npm test)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npx vitest *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)"
    ]
  }
}
