# RC Engine -- AI Service Configuration
#
# SETUP INSTRUCTIONS:
# 1. Copy this file to create your private config:  cp .env.example .env
# 2. Paste your API keys next to the = signs below
# 3. Save and restart your session
#
# Your .env file is private -- it's in .gitignore and will never be shared.

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Powers the core analysis, architecture reasoning, and research synthesis.
# Sign up at: https://console.anthropic.com
# Cost: pay-per-use, typically $1-5 per full research phase
ANTHROPIC_API_KEY=

# ── RECOMMENDED ──────────────────────────────────────────────────────────────
# Provides real-time market research with live web data and cited sources.
# Sign up at: https://www.perplexity.ai/settings/api
# Cost: pay-per-use, typically under $2 per research phase
# Without this: research still works, but won't include live competitor data
PERPLEXITY_API_KEY=

# ── OPTIONAL ─────────────────────────────────────────────────────────────────
# Handles quick classification tasks at very low cost.
# Sign up at: https://aistudio.google.com/apikey
# Cost: free tier covers most usage
# Without this: Claude handles classification instead (works fine)
GOOGLE_GEMINI_API_KEY=

# Enhances UX and content analysis.
# Sign up at: https://platform.openai.com/api-keys
# Cost: pay-per-use, minimal
# Without this: Claude handles UX analysis instead
OPENAI_API_KEY=

# ── Web Server ───────────────────────────────────────────────────────────────
RC_WEB_PORT=3100
# ALLOWED_ORIGINS=http://localhost:3100,https://your-domain.com

# ── Authentication ───────────────────────────────────────────────────────────
# Set to 'true' ONLY for local development (bypasses login requirement)
# RC_AUTH_BYPASS=true

# ── Email (Magic Link) ──────────────────────────────────────────────────────
# Option 1: Resend (recommended)
# RESEND_API_KEY=re_...

# Option 2: SMTP
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@your-domain.com

# If neither is set, magic links are logged to the server console.

# ── Stripe Billing ───────────────────────────────────────────────────────────
# Required only if you want to accept payments.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER_MONTHLY=price_...
# STRIPE_PRICE_STARTER_ANNUAL=price_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_PRO_ANNUAL=price_...

# ── Model Overrides ──────────────────────────────────────────────────────────
# Override default models per provider (optional)
# CLAUDE_MODEL=claude-sonnet-4-5-20250929
# OPENAI_MODEL=gpt-4o
# GEMINI_MODEL=gemini-2.0-flash
# PERPLEXITY_MODEL=sonar-pro
# MAX_TOKENS=16384

# ── Project Directory ────────────────────────────────────────────────────────
# Base directory for project discovery (defaults to $HOME)
# RC_PROJECTS_DIR=/path/to/projects
